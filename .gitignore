# ──────────────────────────────────────────
# Cultiva AI — Root .gitignore
# ──────────────────────────────────────────

# Python virtual environment
backend/.venv/
**/.venv/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyc
.Python

# Environment files (NEVER commit API keys!)
.env
backend/.env
*.env.local
*.env.*.local

# ChromaDB / RAG data (can be regenerated)
backend/rag_data/chroma_db/

# Node.js
frontend/node_modules/
node_modules/

# Next.js build output
frontend/.next/
frontend/out/

# Vercel
frontend/.vercel/

# TypeScript build info
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Docker volumes
pgdata/
redis_data/
