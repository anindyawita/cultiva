# ==========================================
# CULTIVA WEB - CONFIGURATION
# ==========================================

# --- Python & FastAPI (Backend) ---
# Mengabaikan virtual environment di folder mana pun
.venv/
venv/
ENV/
env/

# Mengabaikan cache python (.pyc, __pycache__)
**/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/

# --- Node.js & Next.js (Frontend) ---
# Menghapus tanda '/' di depan agar mendeteksi di dalam subfolder frontend
node_modules/
.next/
out/
build/
coverage/

# Yarn (jika pakai)
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Logs & Debugging ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pip-log.txt

# --- Environment & Security ---
# Mengabaikan semua file .env agar data kredensial tidak bocor ke github
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# --- Sistem Operasi ---
.DS_Store
Thumbs.db

# --- Vercel & TypeScript ---
.vercel
*.tsbuildinfo
next-env.d.ts